{
  "name": "@doudou/bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Doudou Bridge — connects Codex app-server to one or more Doudou devices",
  "bin": {
    "doudou-bridge": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch --clear-screen=false src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@doudou/codex-app-server-protocol": "workspace:*",
    "@doudou/device-protocol": "workspace:*",
    "bonjour-service": "^1.2.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
